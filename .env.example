# Database
# Transaction pooler — used by the app at runtime (port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler — used by Prisma for migrations (port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="change-this-to-a-secure-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-this-to-another-secure-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# App
API_PORT=4000
NODE_ENV=development

# Public Holidays API
PUBLIC_HOLIDAYS_API_URL="https://date.nager.at/api/v3"

# Supabase Storage — for the curriculum library (PDF uploads).
# SUPABASE_URL is the project URL (https://<project-ref>.supabase.co).
# SUPABASE_SERVICE_ROLE_KEY is the service_role secret (Project Settings → API).
# Create a PRIVATE bucket named to match CURRICULUM_BUCKET (default "curriculum").
# When unset, curriculum file upload/download is disabled (pasted links still work).
SUPABASE_URL="https://[project-ref].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret"
CURRICULUM_BUCKET="curriculum"
