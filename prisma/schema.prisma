// ============================================================
// ASSESSMENTS AND SCORES
// ============================================================

model Assessment {
  id             String             @id @default(uuid())
  schoolId       String
  subjectId      String
  classId        String?
  termId         String
  batchId        String?
  category       AssessmentCategory @default(CLASS_TEST)
  title          String
