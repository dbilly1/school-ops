  school      School       @relation(fields: [schoolId], references: [id])
  class       Class        @relation(fields: [classId], references: [id])
  term        Term         @relation(fields: [termId], references: [id])
  assessments Assessment[]

  @@index([schoolId])
  @@index([classId])
  @@map("assessment_batches")
}

model AssessmentScore {
  id           String  @id @default(uuid())
  assessmentId String
  studentId    String
  rawScore     Decimal
  remarks      String?

  assessment Assessment @relation(fields: [assessmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@unique([assessmentId, studentId])
  @@map("assessment_scores")
}

// ============================================================
// STUDENT CATEGORIES AND FINANCE
// ============================================================

model StudentCategory {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  createdAt DateTime @default(now())

  school        School         @relation(fields: [schoolId], references: [id])
  feeStructures FeeStructure[]
  feeItems      FeeItem[]
  students      Student[]

  @@unique([schoolId, name])
  @@map("student_categories")
}

model FeeStructure {
  id                String   @id @default(uuid())
  schoolId          String
  gradeLevelId      String
  studentCategoryId String
  termId            String
  amount            Decimal
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school          School          @relation(fields: [schoolId], references: [id])
  gradeLevel      GradeLevel      @relation(fields: [gradeLevelId], references: [id])
  studentCategory StudentCategory @relation(fields: [studentCategoryId], references: [id])
  term            Term            @relation(fields: [termId], references: [id])

  @@unique([schoolId, gradeLevelId, studentCategoryId, termId])
  @@map("fee_structures")
}

model Invoice {
  id         String    @id @default(uuid())
  schoolId   String
  studentId  String
  termId     String
  amount     Decimal
  amountPaid Decimal   @default(0)
  issuedAt   DateTime  @default(now())
  dueDate    DateTime?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  school   School        @relation(fields: [schoolId], references: [id])
  student  Student       @relation(fields: [studentId], references: [id])
  term     Term          @relation(fields: [termId], references: [id])
  payments Payment[]
  items    InvoiceItem[]

  @@unique([schoolId, studentId, termId])
  @@map("invoices")
}

// Snapshot of the fee line items that make up an invoice's total. Captured at
// generation time (name copied so renaming a component later doesn't rewrite
// history). `isCarryForward` marks the "Balance brought forward" arrears line.
model InvoiceItem {
  id             String  @id @default(uuid())
  invoiceId      String
  feeComponentId String?
  name           String
  amount         Decimal // negative for discount/scholarship lines (isDiscount)
  isCarryForward Boolean @default(false)
  isDiscount     Boolean @default(false)
  sequence       Int     @default(0)

  invoice   Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  component FeeComponent? @relation(fields: [feeComponentId], references: [id])

  @@index([invoiceId])
  @@map("invoice_items")
}

model Payment {
  id          String   @id @default(uuid())
  schoolId    String
  invoiceId   String
  amount      Decimal
  paymentDate DateTime
  method      String?
  reference   String?
  paidBy      String?  // who handed over the money (parent/guardian/sponsor) — distinct from recordedBy (the staff user)
  notes       String?
  recordedBy  String
  createdAt   DateTime @default(now())

  school         School  @relation(fields: [schoolId], references: [id])
  invoice        Invoice @relation(fields: [invoiceId], references: [id])
  recordedByUser User    @relation("PaymentRecordedBy", fields: [recordedBy], references: [id])

  @@index([schoolId])
  @@index([invoiceId])
  @@map("payments")
}

// ============================================================
// FEE COMPONENTS (itemised fee build-up)
// ============================================================

// How often a fee component is billed to a student. PER_TERM = every term's
// invoice (the norm); PER_YEAR = only the student's first invoice of each
// academic year (e.g. annual registration); ONE_TIME = only the student's
// first invoice ever (e.g. admission). Frozen onto the invoice at generation.
enum FeeBillingFrequency {
  PER_TERM
  PER_YEAR
  ONE_TIME
}

// School-level catalog of billable fee components (Tuition, PTA, Exams…).
// Shared across categories so reporting stays consistent; each student
// category selects which ones it bills and at what price (see FeeItem).
model FeeComponent {
  id               String              @id @default(uuid())
  schoolId         String
  name             String
  sequence         Int                 @default(0)
  billingFrequency FeeBillingFrequency @default(PER_TERM)
  isArchived       Boolean             @default(false)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  school       School            @relation(fields: [schoolId], references: [id])
  items        FeeItem[]
  invoiceItems InvoiceItem[]
  discounts    StudentDiscount[]

  @@unique([schoolId, name])
  @@map("fee_components")
}

// A component priced for one student category: a default amount that applies to
// every grade level, optionally overridden per grade (FeeItemOverride). Fees are
// term-agnostic — the current definition is the "terminal" fee, snapshotted onto
// each invoice at generation, so later edits only affect not-yet-billed terms.
model FeeItem {
  id                String   @id @default(uuid())
  schoolId          String
  studentCategoryId String
  feeComponentId    String
  defaultAmount     Decimal  @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  school          School            @relation(fields: [schoolId], references: [id])
  studentCategory StudentCategory   @relation(fields: [studentCategoryId], references: [id])
  component       FeeComponent      @relation(fields: [feeComponentId], references: [id])
  overrides       FeeItemOverride[]

  @@unique([schoolId, studentCategoryId, feeComponentId])
  @@map("fee_items")
}

// Per-grade-level price override for a fee item. Absence ⇒ use defaultAmount.
model FeeItemOverride {
  id           String  @id @default(uuid())
  feeItemId    String
  gradeLevelId String
  amount       Decimal

  feeItem    FeeItem    @relation(fields: [feeItemId], references: [id], onDelete: Cascade)
  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id])

  @@unique([feeItemId, gradeLevelId])
  @@map("fee_item_overrides")
}

// ============================================================
// DISCOUNTS & SCHOLARSHIPS (per-student fee reductions)
// ============================================================

// Labelling only — a scholarship/bursary is mechanically a discount. Lets the
// school report on how reductions are awarded without separate logic.
enum DiscountKind {
  DISCOUNT
  SCHOLARSHIP
  BURSARY
}

enum DiscountType {
  PERCENT // `value` is a percentage 0–100
  FIXED // `value` is a flat GHS amount
}

// A fee reduction awarded to one student. Scope = whole invoice (feeComponentId
// null) or a single component (e.g. tuition-only). Students may hold several at
// once (stackable). Applied at invoice generation as a negative InvoiceItem line
// (isDiscount), capped so the fees portion never goes below zero (arrears are
// never discounted). `frequency` governs recurrence the same way fee components
// do (PER_TERM every term, PER_YEAR first invoice of the year, ONE_TIME once).
model StudentDiscount {
  id             String              @id @default(uuid())
  schoolId       String
  studentId      String
  feeComponentId String? // null = whole invoice; else scoped to one component
  kind           DiscountKind        @default(DISCOUNT)
  type           DiscountType
  value          Decimal
  label          String? // e.g. "Staff child", "Sponsored by Rotary" — prints on the invoice
  frequency      FeeBillingFrequency @default(PER_TERM)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  school    School        @relation(fields: [schoolId], references: [id])
  student   Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  component FeeComponent? @relation(fields: [feeComponentId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@map("student_discounts")
}

