}

// Groups the per-subject assessments of one term-wide exam for a single class
// (e.g. "Primary 4 — End of Term Exam"), so the assessments list shows one row
// per class instead of one row per subject. Created by batchCreate; each child
// Assessment keeps its own scores/grading so report cards are unaffected.
model AssessmentBatch {
  id             String             @id @default(uuid())
  schoolId       String
  classId        String
  termId         String
  category       AssessmentCategory @default(END_OF_TERM_EXAM)
  title          String
  assessmentDate DateTime?
  createdAt      DateTime           @default(now())
