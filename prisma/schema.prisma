// ============================================================
// REPORT CARDS
// ============================================================

model ReportCardConfig {
  id                    String           @id @default(uuid())
  schoolId              String           @unique
  showRawScore          Boolean          @default(true)
  showGradeLabel        Boolean          @default(true)
  showAttendanceSummary Boolean          @default(true)
  showBehaviourScores   Boolean          @default(false)
  showTeacherComments   Boolean          @default(true)
  showPrincipalComments Boolean          @default(true)
  showNextTermInfo      Boolean          @default(false)
  showPosition          Boolean          @default(true)
  // Holistic-style extras (off by default; not every school uses them).
  reportCardLayout      ReportCardLayout @default(STANDARD)
  showAssessmentScale   Boolean          @default(false)
  showMetricsTable      Boolean          @default(false)
  // Terminal-grade weighting: class score (SBA) vs end-of-term exam. GES
  // standards-based default is 50/50; schools may change it (e.g. 30/70).
  sbaWeight             Decimal          @default(50)
  examWeight            Decimal          @default(50)
  footerText            String?
  updatedAt             DateTime         @updatedAt

  school         School                    @relation(fields: [schoolId], references: [id])
  customSections ReportCardCustomSection[]

  @@map("report_card_configs")
}

// School-configurable proficiency levels for the Holistic Development section
// (e.g. E=Emerging, D=Developing, EX=Expected, EE=Exceeding Expectations).
model HolisticProficiencyLevel {
  id          String  @id @default(uuid())
  schoolId    String
  code        String
  label       String
  description String?
  sequence    Int     @default(0)

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("holistic_proficiency_levels")
}

// School-configurable skill rows assessed on the proficiency scale.
model HolisticSkill {
  id         String  @id @default(uuid())
  schoolId   String
  label      String
  groupLabel String?
  sequence   Int     @default(0)

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("holistic_skills")
}

// Optional per-category weighting WITHIN the class-score (SBA) bucket. When no
// rows exist for a school, SBA categories are weighted equally.
model AssessmentCategoryWeight {
  id       String             @id @default(uuid())
  schoolId String
  category AssessmentCategory
  weight   Decimal

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, category])
  @@map("assessment_category_weights")
}

model ReportCardCustomSection {
  id                 String @id @default(uuid())
  reportCardConfigId String
  label              String
  position           Int

  reportCardConfig ReportCardConfig @relation(fields: [reportCardConfigId], references: [id])

  @@map("report_card_custom_sections")
}

model ReportCard {
  id                 String    @id @default(uuid())
  studentId          String
  termId             String
  pdfUrl             String?
  publishedAt        DateTime?
  // Computed snapshot at generation time: per-subject SBA/exam/total/grade.
  data               Json?
  aggregate          Decimal?
  position           Int?
  classSize          Int?
  // When the snapshot was last (re)generated, and a signature of the scores it
  // was built from — used to flag a card as stale when scores change after it
  // was generated.
  generatedAt        DateTime?
  sourceHash         String?
  // Per-student Holistic Development ratings: { [skillId]: levelCode }.
  holistic           Json?
  // GES "Attitudes, Interests & Conduct" section + remarks.
  attitudes          String?
  interests          String?
  conduct            String?
  teacherRemarks     String?
  headTeacherRemarks String?
  promotedTo         String?
  createdAt          DateTime  @default(now())

  student Student @relation(fields: [studentId], references: [id])
  term    Term    @relation(fields: [termId], references: [id])

  @@unique([studentId, termId])
  @@map("report_cards")
}

// ============================================================
// COMMUNICATION
// ============================================================

model Notice {
  id          String    @id @default(uuid())
  schoolId    String
  title       String
  body        String
  publishedAt DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("notices")
}

model Announcement {
  id          String    @id @default(uuid())
  schoolId    String
  title       String
  body        String
  publishedAt DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("announcements")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String   @id @default(uuid())
  schoolId    String
  recipientId String
  eventType   String
  title       String
  body        String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId, recipientId])
  @@map("notifications")
}

model NotificationEventLog {
  id        String   @id @default(uuid())
  schoolId  String
  eventType String
  payload   Json
  createdAt DateTime @default(now())

  @@index([schoolId])
  @@map("notification_event_logs")
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id          String      @id @default(uuid())
  schoolId    String?
  actorId     String
  action      AuditAction
  entityType  String
  entityId    String
  beforeValue Json?
  afterValue  Json?
  ipAddress   String?
  createdAt   DateTime    @default(now())

  school School? @relation(fields: [schoolId], references: [id])
  actor  User    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([schoolId, createdAt])
  @@map("audit_logs")
}
