generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum SubscriptionState {
  TRIAL
  ACTIVE
  SUSPENDED
  EXPIRED
}

enum FeatureState {
  UNAVAILABLE
  AVAILABLE
  ACTIVE
}

enum StaffRole {
  SCHOOL_OWNER
  SCHOOL_ADMIN
  HEADMASTER
  TEACHER
  ACCOUNTANT
  TRANSPORT_OFFICER
}

enum PortalRole {
  STUDENT
  PARENT
}

enum PermissionAction {
  VIEW
  CREATE
  EDIT
  DELETE
}

enum SlotType {
  LESSON
  BREAK
  FREE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum DailyFeeStatus {
  PAID
  PRE_COVERED
  ABSENT
  UNPAID
}

enum AdmissionStage {
  LEAD
  INQUIRY
  APPLICATION
  INTERVIEW
  ACCEPTED
  ENROLLED
  WITHDRAWN
}

enum GradeScaleType {
  PERCENTAGE
  LETTER
  GPA
  CUSTOM
}

// Assessment categories. Everything except END_OF_TERM_EXAM rolls up into the
// continuous-assessment ("class score" / SBA) bucket; END_OF_TERM_EXAM is the
// exam bucket. Mid-term is just an SBA category — it gets no separate tab.
enum AssessmentCategory {
  CLASS_EXERCISE
  CLASS_TEST
  GROUP_WORK
  PROJECT
  HOMEWORK
  MID_TERM
  END_OF_TERM_EXAM
}

// GES education bands — used to tag grade levels so the right curriculum-subject
// template and grading scale apply automatically.
enum EducationLevelType {
  KG
  LOWER_PRIMARY
  UPPER_PRIMARY
  JHS
  SHS
  OTHER
}

// Report card visual layout. STANDARD = the original; HOLISTIC = the
// holistic/competency style (assessment scale + holistic development table).
enum ReportCardLayout {
  STANDARD
  HOLISTIC
}

enum PlannerStatus {
  PLANNED
  DONE
}

// Lesson-note review workflow. DRAFT = teacher editing; SUBMITTED = awaiting
// review; APPROVED = vetted by a reviewer; RETURNED = sent back for revision.
// School-wide policy for how teachers may author lesson-note bodies.
//   STRUCTURED_ONLY — the GES template fields only (default; legacy behaviour).
//   RICH_ALLOWED    — teacher chooses structured or free-form rich text per note.
//   RICH_ONLY       — every note is free-form rich text.
enum LessonNoteFormatPolicy {
  STRUCTURED_ONLY
  RICH_ALLOWED
  RICH_ONLY
}

enum LessonNoteStatus {
  DRAFT
  SUBMITTED
  APPROVED
  RETURNED
}

enum CalendarEventType {
  HOLIDAY
  VACATION
  EXAM_PERIOD
  EVENT
}

enum CalendarEventSource {
  MANUAL
  PUBLIC_HOLIDAY_API
  TENTATIVE_PUBLIC_HOLIDAY
}

enum RateModeType {
  FLAT
  PER_CLASS
}

enum GrantType {
  PERMANENT
  TEMPORARY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PERMISSION_CHANGE
  FEATURE_TOGGLE
  PROGRESSION
  YEAR_ACTIVATION
  TERM_ACTIVATION
  GRANT_ISSUED
}

// ============================================================
// PACKAGES AND FEATURES
// ============================================================

model Package {
  id          String   @id @default(uuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  features PackageFeature[]
  schools  School[]

  @@map("packages")
}

model PackageFeature {
  id            String   @id @default(uuid())
  packageId     String
  featureKey    String
  subFeatureKey String?
  createdAt     DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id])

  @@unique([packageId, featureKey, subFeatureKey])
  @@map("package_features")
}

model SubFeatureDefault {
  id             String  @id @default(uuid())
  featureKey     String
  subFeatureKey  String
  defaultEnabled Boolean @default(false)

  @@unique([featureKey, subFeatureKey])
  @@map("sub_feature_defaults")
}

// ============================================================
// SCHOOLS (TENANTS)
// ============================================================

model School {
  id                        String            @id @default(uuid())
  slug                      String?           @unique
  name                      String
  country                   String
  logoUrl                   String?
  primaryColor              String?
  address                   String?
  phone                     String?
  email                     String?
  studentIdPrefix           String? // Prefix for human-readable student IDs, e.g. "MIS". Defaults to school-name initials.
  studentSeq                Int               @default(0) // Monotonic counter for student-ID sequence; only ever increments.
  packageId                 String?
  subscriptionState         SubscriptionState @default(TRIAL)
  onboardingComplete        Boolean           @default(false)
  adminCanManagePermissions Boolean           @default(true)
  lessonNoteFormatPolicy    LessonNoteFormatPolicy @default(STRUCTURED_ONLY)
  feePaymentGuidelines      String? // Free-text payment instructions (bank/MoMo/deadlines) printed on fee invoices.
  admissionLetterTemplate   String? // Editable admission-letter body with {{merge}} tokens; blank uses the built-in default.
  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  package                   Package?                   @relation(fields: [packageId], references: [id])
  schoolFeatures            SchoolFeature[]
  schoolSubFeatureConfigs   SchoolSubFeatureConfig[]
  schoolFeatureGrants       SchoolFeatureGrant[]
  users                     User[]
  staffProfiles             StaffProfile[]
  gradelevels               GradeLevel[]
  classes                   Class[]
  academicYears             AcademicYear[]
  terms                     Term[]
  calendarEvents            SchoolCalendarEvent[]
  subjects                  Subject[]
  students                  Student[]
  admissionRecords          AdmissionRecord[]
  admissionFieldConfigs     AdmissionFieldConfig[]
  studentCategories         StudentCategory[]
  feeStructures             FeeStructure[]
  feeComponents             FeeComponent[]
  feeItems                  FeeItem[]
  studentDiscounts          StudentDiscount[]
  invoices                  Invoice[]
  payments                  Payment[]
  timetableConfigs          TimetableConfig[]
  assessments               Assessment[]
  assessmentBatches         AssessmentBatch[]
  studentAttendance         StudentAttendanceRecord[]
  staffAttendance           StaffAttendanceRecord[]
  vehicles                  Vehicle[]
  transportRoutes           TransportRoute[]
  drivers                   Driver[]
  notices                   Notice[]
  announcements             Announcement[]
  feedingConfigs            FeedingConfig[]
  feedingEnrollments        FeedingEnrollment[]
  feedingPayments           FeedingPayment[]
  feedingDailyRecords       FeedingDailyRecord[]
  transportPayments         TransportPayment[]
  transportDailyRecords     TransportDailyRecord[]
  reportCardConfigs         ReportCardConfig[]
  notifications             Notification[]
  auditLogs                 AuditLog[]
  rolePermissionOverrides   RolePermissionOverride[]
  userPermissionOverrides   UserPermissionOverride[]
  gradingScales             GradingScale[]
  assessmentCategoryWeights AssessmentCategoryWeight[]
  holisticProficiencyLevels HolisticProficiencyLevel[]
  holisticSkills            HolisticSkill[]
  expenseCategories         ExpenseCategory[]
  expenses                  Expense[]
  expenseBudgets            ExpenseBudget[]
  plannerEntries            PlannerEntry[]
  lessonNotes               LessonNote[]
  curriculumLinks           SchoolCurriculumLink[]

  @@map("schools")
}

model SchoolFeature {
  id          String       @id @default(uuid())
  schoolId    String
  featureKey  String
  state       FeatureState @default(UNAVAILABLE)
  activatedAt DateTime?
  updatedAt   DateTime     @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, featureKey])
  @@map("school_features")
}

model SchoolSubFeatureConfig {
  id            String   @id @default(uuid())
  schoolId      String
  featureKey    String
  subFeatureKey String
  enabled       Boolean  @default(false)
  updatedAt     DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, featureKey, subFeatureKey])
  @@map("school_sub_feature_configs")
}

model SchoolFeatureGrant {
  id            String    @id @default(uuid())
  schoolId      String
  featureKey    String
  subFeatureKey String?
  grantType     GrantType
  expiresAt     DateTime?
  grantedBy     String
  createdAt     DateTime  @default(now())

  school        School @relation(fields: [schoolId], references: [id])
  grantedByUser User   @relation("GrantedByUser", fields: [grantedBy], references: [id])

  @@index([schoolId])
  @@map("school_feature_grants")
}

// ============================================================
// SUPER ADMINS (Platform level — no school affiliation)
// ============================================================

model SuperAdmin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens SuperAdminRefreshToken[]

  @@map("super_admins")
}

model SuperAdminRefreshToken {
  id           String   @id @default(uuid())
  superAdminId String
  tokenHash    String
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  superAdmin SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)

  @@map("super_admin_refresh_tokens")
}

// ============================================================
// REFRESH TOKENS
// ============================================================

model RefreshToken {
  id          String   @id @default(uuid())
  userId      String
  tokenPrefix String?
  tokenHash   String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenPrefix])
  @@map("refresh_tokens")
}

model StudentRefreshToken {
  id          String   @id @default(uuid())
  studentId   String
  tokenPrefix String?
  tokenHash   String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([tokenPrefix])
  @@map("student_refresh_tokens")
}

// ============================================================
// USERS AND PERMISSIONS
// ============================================================

model User {
  id           String   @id @default(uuid())
  schoolId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  tempPassword String? // plain-text kept only while mustChange = true; cleared on first login
  mustChange   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school              School                   @relation(fields: [schoolId], references: [id])
  roles               UserRole[]
  refreshTokens       RefreshToken[]
  staffProfile        StaffProfile?
  roleOverridesSet    RolePermissionOverride[] @relation("OverrideSetBy")
  userOverridesSet    UserPermissionOverride[] @relation("OverrideSetBy")
  userOverrides       UserPermissionOverride[] @relation("OverrideTarget")
  grantsIssued        SchoolFeatureGrant[]     @relation("GrantedByUser")
  auditLogsActed      AuditLog[]               @relation("AuditActor")
  feedingRecorded     FeedingPayment[]         @relation("FeedingRecordedBy")
  transportRecorded   TransportPayment[]       @relation("TransportRecordedBy")
  paymentsRecorded    Payment[]                @relation("PaymentRecordedBy")
  expensesRecorded    Expense[]                @relation("ExpenseRecordedBy")
  plannerEntries      PlannerEntry[]
  lessonNotesAuthored LessonNote[]             @relation("LessonNoteAuthor")
  lessonNotesReviewed LessonNote[]             @relation("LessonNoteReviewer")

  @@unique([schoolId, email])
  @@map("users")
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String
  role      StaffRole
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, role])
  @@map("user_roles")
}

model RolePermissionDefault {
  id            String           @id @default(uuid())
  role          StaffRole
  featureKey    String
  subFeatureKey String?
  action        PermissionAction
  allowed       Boolean

  @@unique([role, featureKey, subFeatureKey, action])
  @@map("role_permission_defaults")
}

model RolePermissionOverride {
  id            String           @id @default(uuid())
  schoolId      String
  role          StaffRole
  featureKey    String
  subFeatureKey String?
  action        PermissionAction
  granted       Boolean
  updatedBy     String
  updatedAt     DateTime         @updatedAt

  school        School @relation(fields: [schoolId], references: [id])
  updatedByUser User   @relation("OverrideSetBy", fields: [updatedBy], references: [id])

  @@unique([schoolId, role, featureKey, subFeatureKey, action])
  @@map("role_permission_overrides")
}

model UserPermissionOverride {
  id            String           @id @default(uuid())
  schoolId      String
  userId        String
  featureKey    String
  subFeatureKey String?
  action        PermissionAction
  granted       Boolean
  updatedBy     String
  updatedAt     DateTime         @updatedAt

  school        School @relation(fields: [schoolId], references: [id])
  user          User   @relation("OverrideTarget", fields: [userId], references: [id])
  updatedByUser User   @relation("OverrideSetBy", fields: [updatedBy], references: [id])

  @@unique([schoolId, userId, featureKey, subFeatureKey, action])
  @@map("user_permission_overrides")
}

// ============================================================
// ACADEMIC YEARS AND TERMS
// ============================================================

model AcademicYear {
  id           String    @id @default(uuid())
  schoolId     String
  name         String
  startDate    DateTime?
  endDate      DateTime?
  isActive     Boolean   @default(false)
  allowOverlap Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  school             School                   @relation(fields: [schoolId], references: [id])
  terms              Term[]
  calendarEvents     SchoolCalendarEvent[]
  studentAssignments StudentClassAssignment[]
  timetableConfigs   TimetableConfig[]
  admissionRecords   AdmissionRecord[]

  @@unique([schoolId, name])
  @@map("academic_years")
}

model Term {
  id             String    @id @default(uuid())
  schoolId       String
  academicYearId String
  name           String
  startDate      DateTime?
  endDate        DateTime?
  isActive       Boolean   @default(false)
  sequence       Int
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  school           School            @relation(fields: [schoolId], references: [id])
  academicYear     AcademicYear      @relation(fields: [academicYearId], references: [id])
  timetableConfigs TimetableConfig[]
  assessments      Assessment[]
  assessmentBatches AssessmentBatch[]
  feeStructures    FeeStructure[]
  invoices         Invoice[]
  reportCards      ReportCard[]
  expenses         Expense[]
  expenseBudgets   ExpenseBudget[]
  lessonNotes      LessonNote[]

  @@unique([academicYearId, sequence])
  @@index([schoolId])
  @@map("terms")
}

// ============================================================
// SCHOOL CALENDAR
// ============================================================

model SchoolCalendarEvent {
  id                 String              @id @default(uuid())
  schoolId           String
  academicYearId     String
  eventType          CalendarEventType
  name               String
  startDate          DateTime
  endDate            DateTime
  source             CalendarEventSource @default(MANUAL)
  externalHolidayKey String?
  confirmedBy        String?
  confirmedAt        DateTime?
  createdAt          DateTime            @default(now())

  school       School       @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id])

  @@index([schoolId])
  @@map("school_calendar_events")
}

// ============================================================
// GRADE LEVELS AND CLASSES
// ============================================================

model GradeLevel {
  id        String              @id @default(uuid())
  schoolId  String
  name      String
  sequence  Int
  levelType EducationLevelType?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  school           School              @relation(fields: [schoolId], references: [id])
  classes          Class[]
  feeStructures    FeeStructure[]
  feeItemOverrides FeeItemOverride[]
  feedingRates     FeedingClassRate[]
  subjects         GradeLevelSubject[]

  @@unique([schoolId, sequence])
  @@map("grade_levels")
}

model Class {
  id           String   @id @default(uuid())
  schoolId     String
  gradeLevelId String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  school             School                    @relation(fields: [schoolId], references: [id])
  gradeLevel         GradeLevel                @relation(fields: [gradeLevelId], references: [id])
  studentAssignments StudentClassAssignment[]
  classTeachers      TeacherClassAssignment[]
  timetableSlots     TimetableSlot[]
  attendanceRecords  StudentAttendanceRecord[]
  assessments        Assessment[]
  assessmentBatches  AssessmentBatch[]
  plannerEntries     PlannerEntry[]
  lessonNotes        LessonNote[]
  admissionRecords   AdmissionRecord[]

  @@unique([schoolId, name])
  @@map("classes")
}

// ============================================================
// STAFF PROFILES AND ASSIGNMENTS
// ============================================================

model StaffProfile {
  id               String    @id @default(uuid())
  schoolId         String
  userId           String    @unique
  staffId          String
  designation      String?
  dateJoined       DateTime?
  employmentType   String?
  dateOfBirth      DateTime?
  gender           String?
  phone            String?
  photoUrl         String?
  emergencyContact Json?
  customFields     Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  school             School                     @relation(fields: [schoolId], references: [id])
  user               User                       @relation(fields: [userId], references: [id])
  qualifications     StaffQualification[]
  classAssignments   TeacherClassAssignment[]
  subjectAssignments TeacherSubjectAssignment[]

  @@unique([schoolId, staffId])
  @@map("staff_profiles")
}

model StaffQualification {
  id             String  @id @default(uuid())
  staffProfileId String
  title          String
  institution    String?
  yearObtained   Int?

  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id])

  @@map("staff_qualifications")
}

model TeacherClassAssignment {
  id             String   @id @default(uuid())
  staffProfileId String
  classId        String
  createdAt      DateTime @default(now())

  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id])
  class        Class        @relation(fields: [classId], references: [id])

  @@unique([staffProfileId, classId])
  @@map("teacher_class_assignments")
}

model TeacherSubjectAssignment {
  id             String   @id @default(uuid())
  staffProfileId String
  subjectId      String
  classId        String
  createdAt      DateTime @default(now())

  staffProfile StaffProfile @relation(fields: [staffProfileId], references: [id])
  subject      Subject      @relation(fields: [subjectId], references: [id])

  @@unique([staffProfileId, subjectId, classId])
  @@map("teacher_subject_assignments")
}

// ============================================================
// SUBJECTS
// ============================================================

model Subject {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school             School                     @relation(fields: [schoolId], references: [id])
  gradeLevels        GradeLevelSubject[]
  subjectAssignments TeacherSubjectAssignment[]
  timetableSlots     TimetableSlot[]
  assessments        Assessment[]
  plannerEntries     PlannerEntry[]
  lessonNotes        LessonNote[]

  @@unique([schoolId, name])
  @@map("subjects")
}

model GradeLevelSubject {
  id           String @id @default(uuid())
  gradeLevelId String
  subjectId    String

  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id])
  subject    Subject    @relation(fields: [subjectId], references: [id])

  @@unique([gradeLevelId, subjectId])
  @@map("grade_level_subjects")
}

// Platform-level GES subject catalog, managed by the super admin. Schools apply
// it during setup: subjects are copied into per-school Subject rows + linked to
// grade levels by matching levelType. Not tenant-scoped.
model CurriculumSubject {
  id        String             @id @default(uuid())
  levelType EducationLevelType
  name      String
  code      String?
  sequence  Int                @default(0)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([levelType, name])
  @@map("curriculum_subjects")
}

// Platform-level shared curriculum library (super-admin owned, NOT tenant-scoped
// — like CurriculumSubject). The official GES curriculum PDFs, uploaded once and
// referenced by every school. The file lives in Supabase Storage; `fileKey` is
// its path within the bucket. Tagged by level band + subject name so schools can
// filter to what's relevant.
model CurriculumResource {
  id          String               @id @default(uuid())
  // A document can span several level bands (e.g. a cumulative B1–B6 curriculum),
  // so it carries the full set of levels it applies to.
  levelTypes  EducationLevelType[]
  subjectName String
  title       String
  description String?
  fileKey     String // path within the storage bucket
  fileName    String
  fileSize    Int
  mimeType    String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([levelTypes], type: Gin)
  @@map("curriculum_resources")
}

// Per-school curriculum links — a school's own supplementary materials, stored
// as pasted URLs (zero storage). Managed by Owner/Admin/Headmaster, visible to
// teachers.
model SchoolCurriculumLink {
  id          String              @id @default(uuid())
  schoolId    String
  levelType   EducationLevelType?
  subjectName String?
  title       String
  url         String
  description String?
  createdBy   String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("school_curriculum_links")
}

// Personal day/week planner — private to each staff user (any role). A free-form
// to-do keyed to a date, optionally tagged with a class/subject the user teaches.
// Owner-scoped by userId (NOT a review artifact — that's LessonNote).
model PlannerEntry {
  id        String        @id @default(uuid())
  schoolId  String
  userId    String
  date      DateTime // the day it's planned for (date-only; stored at UTC midnight)
  title     String
  notes     String?
  color     String? // optional palette key (slate/emerald/blue/amber/rose/violet)
  status    PlannerStatus @default(PLANNED)
  position  Int           @default(0) // ordering within a day
  classId   String?
  subjectId String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  school  School   @relation(fields: [schoolId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  class   Class?   @relation(fields: [classId], references: [id])
  subject Subject? @relation(fields: [subjectId], references: [id])

  @@index([userId, date])
  @@index([schoolId])
  @@map("planner_entries")
}

// Weekly lesson note — a formal artifact a teacher submits and a reviewer
// (Headmaster/admin, or anyone granted academics:lesson_note_review) vets.
// Content is a structured GES template stored as JSON (text-in-DB; no files):
//   { strand, subStrand, contentStandard, indicators, objectives, resources,
//     references, lessons: [{ day?, phase1Starter, phase2Main, phase3Plenary }] }
// One note per teacher × class × subject × week (weekEnding).
model LessonNote {
  id             String           @id @default(uuid())
  schoolId       String
  authorId       String
  classId        String
  subjectId      String
  termId         String
  weekEnding     DateTime // GES week-ending date; the week key
  title          String?
  content        Json // structured GES template (header fields + lessons[])
  status         LessonNoteStatus @default(DRAFT)
  submittedAt    DateTime?
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewComments String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  school   School  @relation(fields: [schoolId], references: [id])
  author   User    @relation("LessonNoteAuthor", fields: [authorId], references: [id])
  reviewer User?   @relation("LessonNoteReviewer", fields: [reviewedBy], references: [id])
  class    Class   @relation(fields: [classId], references: [id])
  subject  Subject @relation(fields: [subjectId], references: [id])
  term     Term    @relation(fields: [termId], references: [id])

  @@unique([authorId, classId, subjectId, weekEnding])
  @@index([schoolId, status])
  @@index([authorId])
  @@map("lesson_notes")
}

// ============================================================
// GRADING
// ============================================================

model GradingScale {
  id                     String         @id @default(uuid())
  schoolId               String
  scaleType              GradeScaleType
  passmark               Decimal?
  gpaMax                 Decimal?
  isActive               Boolean        @default(true)
  // Grade levels this scale applies to. Empty = school-wide default/fallback
  // (e.g. Primary uses an A–F scale, JHS uses a 1–9 scale, simultaneously).
  appliesToGradeLevelIds String[]       @default([])
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  school School             @relation(fields: [schoolId], references: [id])
  bands  GradingScaleBand[]

  @@index([schoolId])
  @@map("grading_scales")
}

model GradingScaleBand {
  id             String   @id @default(uuid())
  gradingScaleId String
  label          String
  minScore       Decimal
  maxScore       Decimal
  gpaValue       Decimal?
  remark         String?

  gradingScale GradingScale @relation(fields: [gradingScaleId], references: [id])

  @@map("grading_scale_bands")
}

// ============================================================
// TIMETABLES
// ============================================================

model TimetableConfig {
  id                    String   @id @default(uuid())
  schoolId              String
  academicYearId        String
  termId                String
  periodsPerDay         Int
  periodDurationMinutes Int
  schoolDays            String[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  school       School           @relation(fields: [schoolId], references: [id])
  academicYear AcademicYear     @relation(fields: [academicYearId], references: [id])
